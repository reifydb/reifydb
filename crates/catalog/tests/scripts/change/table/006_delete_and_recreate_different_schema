# Drop table and recreate with completely different columns, verify columns change

admin 'CREATE NAMESPACE app'
admin 'CREATE TABLE app::events { ts: int8, msg: utf8 }'
replicate
---
version: 2

query 'FROM system::columns FILTER {shape_id == 1025} SORT {position:ASC}'
