# Sequential replicates at different versions

admin 'CREATE NAMESPACE first'
replicate
---
version: 2

admin 'CREATE NAMESPACE second'
replicate
---
version: 3

query 'FROM system::namespaces FILTER {name == "first" or name == "second"} SORT {name:ASC}'
