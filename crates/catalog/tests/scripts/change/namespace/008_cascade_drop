# Drop namespace cascades to tables within it

admin 'CREATE NAMESPACE cascade_ns'
admin 'CREATE TABLE cascade_ns::t1 { id: int4 }'
admin 'CREATE TABLE cascade_ns::t2 { id: int4 }'
replicate
---
version: 2

query 'FROM system::tables FILTER {name == "t1" or name == "t2"} SORT {name:ASC}'
---
+---------+----------------+--------+------------------+
|   id    |  namespace_id  |  name  |  primary_key_id  |
+---------+----------------+--------+------------------+
|  16385  |     16385      |   t1   |       none       |
|  16386  |     16385      |   t2   |       none       |
+---------+----------------+--------+------------------+

admin 'DROP NAMESPACE cascade_ns CASCADE'
replicate
---
version: 3

query 'FROM system::namespaces FILTER {name == "cascade_ns"}'
---
+------+--------+--------------+-------------+
|  id  |  name  |  local_name  |  parent_id  |
+------+--------+--------------+-------------+
+------+--------+--------------+-------------+

query 'FROM system::tables FILTER {name == "t1" or name == "t2"}'
---
+------+----------------+--------+------------------+
|  id  |  namespace_id  |  name  |  primary_key_id  |
+------+----------------+--------+------------------+
+------+----------------+--------+------------------+
