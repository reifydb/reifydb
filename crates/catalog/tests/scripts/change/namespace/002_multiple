# Multiple namespaces in a single replicate batch

admin 'CREATE NAMESPACE ns1'
admin 'CREATE NAMESPACE ns2'
admin 'CREATE NAMESPACE ns3'
replicate
---
version: 2

query 'FROM system::namespaces FILTER {name == "ns1" or name == "ns2" or name == "ns3"} SORT {name:ASC}'
