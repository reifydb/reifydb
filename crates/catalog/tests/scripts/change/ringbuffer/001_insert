# Create a ringbuffer, replicate, verify

admin 'CREATE NAMESPACE rb'
admin 'CREATE RINGBUFFER rb::logs { level: utf8, msg: utf8 } WITH { capacity: 100 }'
replicate
---
version: 2

query 'FROM system::ringbuffers FILTER {name == "logs"}'
---
