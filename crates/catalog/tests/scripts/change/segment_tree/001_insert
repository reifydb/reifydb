# Create a segment tree, replicate, verify

admin 'CREATE NAMESPACE si'
create_segment_tree 'si::readings' aggregates='total|math::sum|value'
replicate
---
version: 2

query 'FROM system::segment_trees FILTER {name == "readings"}'
---
+---------+----------------+------------+--------------+-------------------------+----------------+---------------------------+
|   id    |  namespace_id  |    name    |  key_column  |        key_kind         |  partition_by  |        aggregates         |
