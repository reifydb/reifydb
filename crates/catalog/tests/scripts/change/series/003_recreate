# Create series, delete, recreate with different schema

admin 'CREATE NAMESPACE si'
admin 'CREATE SERIES si::metrics { timestamp: datetime, value: float8 } WITH { key: timestamp }'
replicate
---
version: 2

query 'FROM system::series FILTER {name == "metrics"}'
---
+--------+----------------+-----------+----------+--------------+-------------------------+
|   id   |  namespace_id  |   name    |  tag_id  |  key_column  |        key_kind         |
+--------+----------------+-----------+----------+--------------+-------------------------+
|  1025  |      1025      |  metrics  |   none   |  timestamp   |  datetime(millisecond)  |
+--------+----------------+-----------+----------+--------------+-------------------------+

(admin 'DROP SERIES si::metrics')
replicate
---
version: 3

query 'FROM system::series FILTER {name == "metrics"}'
---
+------+----------------+--------+----------+--------------+------------+
|  id  |  namespace_id  |  name  |  tag_id  |  key_column  |  key_kind  |
+------+----------------+--------+----------+--------------+------------+
+------+----------------+--------+----------+--------------+------------+

admin 'CREATE SERIES si::metrics { timestamp: datetime, sensor_id: int4, reading: float8 } WITH { key: timestamp }'
replicate
