# Create a series, replicate, verify

admin 'CREATE NAMESPACE si'
admin 'CREATE SERIES si::metrics { timestamp: datetime, value: float8 } WITH { key: timestamp }'
replicate
---
version: 2

query 'FROM system::series FILTER {name == "metrics"}'
