# Create deferred view, verify, drop, verify gone

admin 'CREATE NAMESPACE vw'
admin 'CREATE TABLE vw::data { id: int4, val: utf8 }'
admin 'CREATE DEFERRED VIEW vw::summary { id: int4, val: utf8 } AS { FROM vw::data MAP { id: id, val: val } }'
replicate
---
version: 2

query 'FROM system::views FILTER {name == "summary"}'
---
