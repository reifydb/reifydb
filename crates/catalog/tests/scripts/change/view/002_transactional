# Create a transactional view, replicate, verify

admin 'CREATE NAMESPACE vw'
admin 'CREATE TABLE vw::users { id: int4, name: utf8, active: bool }'
admin 'CREATE VIEW vw::active_users { id: int4, name: utf8 } AS { FROM vw::users FILTER active == true MAP { id: id, name: name } }'
replicate
---
version: 2

query 'FROM system::views FILTER {name == "active_users"}'
