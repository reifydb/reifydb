# Scenario: All comparison operators
# Why: Validates that _gt, _gte, _lt, and _lte suffixes are correctly mapped to
#      their respective RQL infix operators inside the root level's LET filter.
(admin 'CREATE TABLE transactions { id: int4, hash: utf8, block: int4, index: int4 }')
query 'CALL graphql::explain("query { transactions(where: { block_gt: 10, block_gte: 11, index_lt: 5, index_lte: 4 }) { hash } }")'
---
> +-------+------------+---------------------------------------------------------------------------------------------------------------+
> |  idx  |    kind    |                                                    detail                                                     |
> +-------+------------+---------------------------------------------------------------------------------------------------------------+
> |   0   |    Let     |  $level0 = from transactions | filter block > 10 | filter block >= 11 | filter index < 5 | filter index <= 4  |
> |   1   |    Let     |                                                  $rows = []                                                   |
> |   2   |    For     |                                                $r0 in $level0                                                 |
> |   3   |   Append   |                                          $rows from [{hash: $r0.hash}]                                        |
> |   4   |  Variable  |                                                     $rows                                                     |
> +-------+------------+---------------------------------------------------------------------------------------------------------------+
>
