# Read-your-writes within an uncommitted replica transaction.

t1: begin_replica version=100
t1: set a=1
t1: get a
---
t1: "a" => "1"

t1: set b=2
t1: scan
---
t1: "a" => "1"
t1: "b" => "2"

t1: commit_replica
---
ok
