# A tombstone in __current (value=None) is skipped by the scanner: there is no
# live value to expire. The row's stale historical version is NOT reaped by TTL
# - that is what MVCC compaction (find_keys_to_drop) handles. Lock in behavior.

set 1=alive version=1
tombstone 1 version=2
---
ok
ok

count_current
count_historical
---
current: 1
historical: 1

versions 1
---
v2 tombstone
v1 value="alive"

scan_ttl cutoff=5
---
expired=0 versions_dropped=0

count_current
count_historical
---
current: 1
historical: 1
