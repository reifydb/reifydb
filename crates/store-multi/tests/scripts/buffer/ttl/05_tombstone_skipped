# Tombstone in __current is skipped by the scanner (value=None has no
# trailer to read created_at from). The row's stale historical version is
# NOT reaped by TTL - that's what MVCC compaction (find_keys_to_drop)
# handles. Lock in current behavior.

set 1=alive version=1 created=1000
tombstone 1 version=2
---
ok
ok

count_current
count_historical
---
current: 1
historical: 1

versions 1
---
v2 tombstone
v1 created=1000 updated=1000 value="alive"

scan_ttl mode=created duration=5000 now=10000
---
expired=0 versions_dropped=0

count_current
count_historical
---
current: 1
historical: 1
