# Out-of-order write: V5 lands first (becomes current), then V3 arrives later
# (lower version, parked in __historical). The scanner inspects the CURRENT
# version (V5). A cutoff at V5 expires the key and drops every version it owns,
# including the V3 historical entry. Lock in this behavior.

set 1=v5 version=5
set 1=v3 version=3
---
ok
ok

count_current
count_historical
---
current: 1
historical: 1

versions 1
---
v5 value="v5"
v3 value="v3"

scan_ttl cutoff=5
---
expired=1 versions_dropped=2

count_current
count_historical
---
current: 0
historical: 0
