# Bug 1 fix verification: dropping ONLY the current version while
# historical versions remain must promote the next-newest historical
# row into current. Memory and SQLite must agree on this outcome.
#
# Setup: V1 and V3 in __historical, V5 in __current.
# Drop only V5.
# Expected: current=V3, historical=[V1] on both backends.

set 1=v1 version=1 created=1000
set 1=v3 version=3 created=1000
set 1=v5 version=5 created=1000
