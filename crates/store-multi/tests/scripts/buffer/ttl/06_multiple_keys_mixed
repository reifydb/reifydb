# Multiple keys with mixed expiry status. Only keys whose current version is at
# or below the cutoff go away; keys written after the cutoff are untouched in
# both physical tables. Freshness is the commit version, so the surviving key
# is written last (highest version).

# Row 1: single old version (current only, expired)
set 1=row1 version=1
# Row 3: two old versions (current + historical, both expired)
set 3=row3a version=2
set 3=row3b version=3
# Row 2: newest version (above the cutoff, NOT expired)
set 2=row2 version=4
---
ok
ok
ok
ok

count_current
count_historical
---
current: 3
historical: 1

scan_ttl cutoff=3
---
expired=2 versions_dropped=3

