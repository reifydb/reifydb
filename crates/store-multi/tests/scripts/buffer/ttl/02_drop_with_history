# Row with three versions: V1 and V2 in __historical, V3 in __current. The
# current version (V3) is at or below the cutoff, so the whole key expires and
# ALL its versions are dropped. Both physical tables must be empty afterwards
# (covers the bulk-drop fast path in drop_versions_from_split / memory drop).

set 1=v1 version=1
set 1=v2 version=2
set 1=v3 version=3
---
ok
ok
ok

count_current
count_historical
---
current: 1
historical: 2

versions 1
---
v3 value="v3"
v2 value="v2"
v1 value="v1"

scan_ttl cutoff=5
---
expired=1 versions_dropped=3

count_current
count_historical
---
current: 0
historical: 0

versions 1
---
(none)

visible 1
