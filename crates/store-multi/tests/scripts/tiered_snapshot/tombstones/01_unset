# Defect targets (coupled-flush model):
#   - sweep silently dropping an Unset tombstone instead of persisting it
#   - tombstone not persisted as the latest-<=W value (persistent reports stale "alive")
#   - cascade resurrecting a deleted key from an evicted pre-delete version

watermark 2
---
ok

set k=alive   version=1
flush
---
ok

# The first sweep persisted the live value at v1.
persistent_get k version=1
---
"k" => "alive"

# Tombstone via Unset at v2, then sweep at W=2.
unset k=alive   version=2
flush
---
ok

# The tombstone is the latest-<=W value, so it persists: None at and after v=2.
persistent_get k version=2
---
"k" => None

# Cascade at v=2: the persisted tombstone short-circuits to None (no resurrection).
get k version=2
---
"k" => None

# Cascade at v=1: the pre-delete "alive" was evicted from the commit tier and
# persistent rejects stored_version(2) > requested(1) -> unreachable.
get k version=1
---
"k" => None
