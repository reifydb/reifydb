# Defect targets:
#   - listener treating Remove differently from Unset (both produce a
#     tombstone in buffer's __current; persistent should mirror that as None)
#   - Remove deltas not classified into the tombstones map

set k=alive   version=1
flush
---
ok

persistent_get k version=1
---
"k" => "alive"

remove k   version=2
flush
---
ok

persistent_get k version=2
---
"k" => None

get k version=2
---
"k" => None

get k version=1
---
"k" => "alive"
