# Defect targets (coupled-flush model):
#   - sweep treating Remove differently from Unset (both produce a tombstone that
#     must persist as None when it is the latest-<=W value)
#   - Remove tombstones not persisted, leaving a stale live value behind

watermark 2
---
ok

set k=alive   version=1
flush
---
ok

persistent_get k version=1
---
"k" => "alive"

remove k   version=2
flush
---
ok

# Remove behaves like Unset: the v2 tombstone is the latest-<=W value and persists.
persistent_get k version=2
---
"k" => None

get k version=2
---
"k" => None

# Pre-delete "alive" at v1 was evicted and persistent rejects below v2 -> unreachable.
get k version=1
---
"k" => None
