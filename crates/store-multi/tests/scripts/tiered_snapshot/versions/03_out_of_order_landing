# Defect targets:
#   - missing or broken regression guard in build_upsert_warm_current_sql
#   - drain writing the older version over the newer one in persistent
#
# Sequence:
#   1. Commit at v=3 (becomes buffer's __current).
#   2. Flush -> persistent has (k, v=3, "high").
#   3. Commit at v=1 (older than current; lands in buffer's __historical).
#   4. Flush -> drain reads buffer at v=1, finds "low" (from historical), sends
#      upsert (k, v=1, "low") to persistent. Persistent's regression guard rejects it
#      because persistent's existing version (3) > incoming (1). Persistent stays at
#      (k, v=3, "high").

set k=high   version=3
flush
---
ok

set k=low   version=1
flush
---
ok

# Persistent must NOT have regressed
persistent_get k version=3
---
"k" => "high"

# Reads below the stored version are rejected
persistent_get k version=1
---
"k" => None

# Buffer still serves v=1 from its historical chain
buffer_get k version=1
---
"k" => "low"

# Cascade is historical-aware via buffer
get k version=1
---
"k" => "low"

get k version=3
---
"k" => "high"
