# Defect targets (coupled-flush model):
#   - sweep persisting the wrong version when a key is written several times below W
#     (must persist the highest version <= W, here v3="C", not an earlier one)
#   - sweep persisting more than one version per key
#   - persistent overwriting itself with stale data instead of the latest-<=W value

set k=A   version=1
set k=B   version=2
set k=C   version=3
watermark 3
flush
---
ok
ok

# The sweep at W=3 persists ONLY the latest-<=W value (v3="C") and evicts every
# <=W version (v1, v2, v3) from the commit tier.
persistent_get k version=3
---
"k" => "C"

# Every <=W version is gone from the commit tier - including the latest.
buffer_get k version=3
---
"k" => None

# Reads at the watermark resolve to the persisted latest value from persistent.
get k version=3
---
"k" => "C"

# Reads below the latest-<=W version are NotFound: those older versions were
# evicted from the commit tier and persistent rejects stored_version(3) > requested.
# This is correct - no live reader sits below W, so that history is unreachable.
get k version=1
---
"k" => None

get k version=2
---
"k" => None
