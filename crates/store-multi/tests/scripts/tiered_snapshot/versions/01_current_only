# Defect targets:
#   - persistent storing the wrong version (e.g. an earlier one)
#   - drain mishandling a key written multiple times in one batch (last-write-wins
#     in upsert_pending should pick the highest version)
#   - persistent overwriting itself with stale data instead of latest

set k=A   version=1
set k=B   version=2
set k=C   version=3
flush
---
ok

# Persistent stores ONLY the latest committed value
persistent_get k version=3
---
"k" => "C"

# Cascade reads at older versions still find A and B via buffer's __historical
get k version=1
---
"k" => "A"

get k version=2
---
"k" => "B"

get k version=3
---
"k" => "C"
