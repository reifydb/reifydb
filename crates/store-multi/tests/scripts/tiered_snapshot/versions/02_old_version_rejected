# Defect targets:
#   - persistent.get returning the stored value when stored_version > requested_version
#     (would falsely show a value at a snapshot before it existed)

set k=v3   version=3
flush
---
ok

# Persistent has stored_version=3. Reads at lower versions must return None
# (the value did not exist at that snapshot).
persistent_get k version=1
---
"k" => None

persistent_get k version=2
---
"k" => None

# At and after stored_version, persistent answers
persistent_get k version=3
---
"k" => "v3"

persistent_get k version=99
---
"k" => "v3"
