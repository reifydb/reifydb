# get_many resolves every key from the correct tier in a single batched call:
# a -> persistent (flushed), b -> buffer (not flushed), c -> absent.

set a=apple version=1
flush
---
ok

set b=berry version=2
---
ok

get_many a b c version=2
---
"a" => "apple"
"b" => "berry"
"c" => None
