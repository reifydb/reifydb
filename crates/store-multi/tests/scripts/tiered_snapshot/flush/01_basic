set k=1     version=1
---
ok

# No flush yet -> persistent must be empty
persistent_get k version=1
---
"k" => None

# Pin the eviction watermark at W=1. v1 <= W, so the coupled sweep both persists
# the latest-<=W value AND evicts it from the commit tier.
watermark 1
flush
---
ok
ok

# The swept value now lives in the persistent tier at its committed version.
persistent_get k version=1
---
"k" => "1"
