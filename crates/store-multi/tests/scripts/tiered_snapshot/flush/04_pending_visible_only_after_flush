# Defect targets:
#   - speculative persistent updates on commit
#   - drain firing without an explicit trigger (background timer racing in)

set k=A   version=1
flush
---
ok

# Subsequent writes accumulate in pending but persistent should still report A
set k=B   version=2
set k=C   version=3
---
ok

persistent_get k version=3
---
"k" => "A"

# After explicit flush, persistent jumps to C (latest current)
flush
---
ok

persistent_get k version=3
---
"k" => "C"

# At older versions persistent rejects (stored_version=3 > requested)
persistent_get k version=1
---
"k" => None

persistent_get k version=2
---
"k" => None
