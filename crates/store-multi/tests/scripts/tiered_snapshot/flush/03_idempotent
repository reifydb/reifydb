# Defect targets (coupled-flush model):
#   - a repeated sweep at the same watermark mutating persistent a second time
#   - panic / error when a sweep finds nothing left to evict below W
#   - re-persisting a value the previous sweep already evicted from the commit tier

set k=1   version=1
watermark 1
flush
flush
flush
---
ok
ok
ok
ok

# The first sweep persisted v1 and evicted it from the commit tier; the second and
# third sweeps find nothing at/below W=1 still resident, so persistent stays at "1".
persistent_get k version=1
---
"k" => "1"
