# Verifies storage classifies Value / Tombstone / NotFound in a single
# query (the non-lossy get). An absent key and an in-range delete must be distinguishable -
# the old Option<value> return collapsed both to None.
#
# Coupled-flush model: a single watermark W=2 governs every sweep below. The first
# sweep persists the live v1 row; the second sweep (after the delete) persists the
# v2 tombstone as the new latest-<=W row.

watermark 2
---
ok

# Absent key -> notfound, not tombstone
persistent_get_state k version=1
---
"k" => notfound

# Value written and swept into persistent at v1 (v1 <= W)
set k=alive version=1
flush
---
ok

persistent_get_state k version=1
---
"k" => "alive" version=1

# Visible from a later snapshot, still reported at its stored version
persistent_get_state k version=9
---
"k" => "alive" version=1

# Below the write the row is not yet visible -> notfound, never tombstone
persistent_get_state k version=0
---
"k" => notfound

# Delete at v2; sweep at W=2 persists the tombstone as the latest-<=W row
unset k=alive version=2
flush
---
ok

# In-range delete is a Tombstone, distinct from NotFound
persistent_get_state k version=2
---
"k" => tombstone

# Persistent keeps only the latest row; below the tombstone version -> notfound
persistent_get_state k version=1
---
"k" => notfound
