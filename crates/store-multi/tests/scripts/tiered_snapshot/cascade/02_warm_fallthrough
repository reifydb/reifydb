# Defect targets:
#   - cascade not consulting warm on hot NotFound
#   - get_at_version's tombstone disambiguation incorrectly returning
#     Tombstone for a key warm actually has

# Plant a value directly in warm. Hot never sees this key.
warm_set k=warm_planted   version=5
---
ok

# Hot has nothing
hot_get k version=5
---
"k" => None

# Warm has the planted value
warm_get k version=5
---
"k" => "warm_planted"

# Cascade falls through hot -> warm and returns the warm value
get k version=5
---
"k" => "warm_planted"
