# Defect targets:
#   - cascade order reversed (warm consulted before hot)
#   - cascade merging instead of short-circuiting
#   - get_at_version on hot returning NotFound when hot actually has the value

set k=hot_value   version=1
flush
---
ok

# Force divergence: warm_set bypasses the actor and writes warm directly
warm_set k=warm_only_value   version=1
---
ok

# Cascade returns hot's value, not warm's
get k version=1
---
"k" => "hot_value"

# Direct reads confirm divergence is real
hot_get k version=1
---
"k" => "hot_value"

warm_get k version=1
---
"k" => "warm_only_value"
