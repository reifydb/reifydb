# Tests that dropped keys can be set and removed again.

# Insert and drop (keeps latest)
set a=1 version=1
---
ok

count_versions a
---
"a" => 1 versions

drop a
---
ok

count_versions a
---
"a" => 1 versions

contains a version=1
---
"a" => true

# Set again after drop
set a=new version=2
---
ok

count_versions a
---
"a" => 2 versions

contains a version=2
---
"a" => true

get a version=2
---
"a" => "new"

# Remove the re-inserted key
remove a version=3
---
ok

contains a version=3
---
"a" => false

# Set again after remove
set a=final version=4
---
ok

get a version=4
---
"a" => "final"

# Drop again
drop a
---
ok

# count_versions skips tombstones (v3 is tombstone, v1/v2 historical dropped, v4 remains)
count_versions a
---
"a" => 1 versions

# And set once more
set a=resurrected version=5
---
ok

count_versions a
---
"a" => 2 versions

get a version=5
---
"a" => "resurrected"
