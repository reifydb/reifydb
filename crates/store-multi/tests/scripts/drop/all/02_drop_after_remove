# Tests drop after a key has been removed (tombstone exists).

set a=1 version=1
remove a version=2
---
ok

# Key does not exist at version 2 due to tombstone
contains a version=2
---
"a" => false

# But version 1 still exists
contains a version=1
---
"a" => true

# Count shows 1 version (the set, not the tombstone)
count_versions a
---
"a" => 1 versions

# Drop historical versions (keeps latest tombstone at v2)
drop a
---
ok

# 0 versions remain because v2 was a tombstone
count_versions a
---
"a" => 0 versions

# v1 is gone
contains a version=1
---
"a" => false

# v2 is still a tombstone
contains a version=2
---
"a" => false
