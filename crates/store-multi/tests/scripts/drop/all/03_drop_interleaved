# Tests interleaved insert/drop/insert operations.

# Initial insert
set a=1 version=1
---
ok

count_versions a
---
"a" => 1 versions

contains a version=1
---
"a" => true

# Drop (but only one version exists, so it should keep it)
drop a
---
ok

count_versions a
---
"a" => 1 versions

contains a version=1
---
"a" => true

# Re-insert after drop
set a=new version=2
---
ok

count_versions a
---
"a" => 2 versions

contains a version=2
---
"a" => true

get a version=2
---
"a" => "new"

# Drop again - keeps version 2, drops version 1
drop a
---
ok

count_versions a
---
"a" => 1 versions

contains a version=1
---
"a" => false

# Set final value
set a=final version=3
---
ok

count_versions a
---
"a" => 2 versions

get a version=3
---
"a" => "final"
