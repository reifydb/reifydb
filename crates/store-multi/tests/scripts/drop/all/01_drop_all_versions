# Tests basic drop that removes historical versions of a key.

set a=1 version=1
set a=2 version=2
set a=3 version=3
---
ok

# Count versions before drop
count_versions a
---
"a" => 3 versions

# Verify key exists at latest version
contains a version=3
---
"a" => true

# Drop historical versions (keeps latest)
drop a
---
ok

# Count versions after drop - should be 1
count_versions a
---
"a" => 1 versions

# Historical versions 1 and 2 are gone
contains a version=1
contains a version=2
---
"a" => false
"a" => false

# Latest version 3 remains
contains a version=3
---
"a" => true

# All get operations for historical return None
get a version=1
get a version=2
---
"a" => None
"a" => None

# Latest version is still accessible
get a version=3
---
"a" => "3"
