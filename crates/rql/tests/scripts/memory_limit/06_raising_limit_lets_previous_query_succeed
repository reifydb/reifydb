# query_budget() reads QUERY_MEMORY_LIMIT fresh at every query, so raising the limit
# must let the same query that just failed succeed - no restart required.

admin 'create table test::wide6 { n: int4 }'
---
> +---------+-------------+---------+-----------+
> |   id    |  namespace  |  table  |  created  |
> +---------+-------------+---------+-----------+
> |  16388  |    test     |  wide6  |   true    |
> +---------+-------------+---------+-----------+
>

command 'insert test::wide6 [{n:3},{n:1},{n:2}]'
---
> +-------------+---------+------------+
> |  namespace  |  table  |  inserted  |
> +-------------+---------+------------+
> |    test     |  wide6  |     3      |
> +-------------+---------+------------+
>

set_config QUERY_MEMORY_LIMIT 8
---
ok

query_fails 'from test::wide6 sort {n}'
---
Error QUERY_006

set_config QUERY_MEMORY_LIMIT 1073741824
---
ok

query 'from test::wide6 sort {n}'
---
> +-----------+----------------------------------+----------------------------------+-----+
> |  #rownum  |           #created_at            |           #updated_at            |  n  |
