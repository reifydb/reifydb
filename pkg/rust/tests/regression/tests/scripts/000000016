(admin 'CREATE NAMESPACE test')
(admin 'CREATE SERIES test::s { ts: int8, val: int8 } WITH { key: ts }')
(admin 'CREATE TABLE test::src { ts: int8, val: int8 }')
(command 'INSERT test::src [{ ts: 1000, val: 42 }]')
command 'LET $x = FROM test::src; INSERT test::s $x RETURNING { ts, val }'
---
> +-----------+----------------------------------+----------------------------------+--------+-------+
> |  #rownum  |           #created_at            |           #updated_at            |   ts   |  val  |
> +-----------+----------------------------------+----------------------------------+--------+-------+
> |     1     |  1970-01-01T00:00:00.000000000Z  |  1970-01-01T00:00:00.000000000Z  |  1000  |  42   |
> +-----------+----------------------------------+----------------------------------+--------+-------+
>
