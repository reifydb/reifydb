(admin 'CREATE NAMESPACE test')
(admin 'CREATE RINGBUFFER test::rb { id: int4, name: utf8 } WITH { capacity: 10 }')
(command 'INSERT test::rb [{ id: 1, name: "a" }, { id: 2, name: "b" }]')
command 'LET $x = 2; DELETE test::rb FILTER id == $x RETURNING { id, name }'
---
> +-----------+------+--------+
> |  #rownum  |  id  |  name  |
> +-----------+------+--------+
> |     2     |  2   |   b    |
> +-----------+------+--------+
>
