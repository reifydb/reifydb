(admin 'CREATE NAMESPACE test')
(admin 'CREATE RINGBUFFER test::rb { id: int4, name: utf8 } WITH { capacity: 10 }')
(admin 'CREATE TABLE test::src { id: int4, name: utf8 }')
(command 'INSERT test::src [{ id: 1, name: "a" }]')
command 'LET $x = FROM test::src; INSERT test::rb $x RETURNING { id, name }'
---
> +-----------+------+--------+
> |  #rownum  |  id  |  name  |
> +-----------+------+--------+
> |     1     |  1   |   a    |
> +-----------+------+--------+
>
