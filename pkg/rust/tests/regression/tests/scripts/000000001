(admin 'create namespace test')
(admin 'create table test::arith{id: int2, num: int2}')
(command '
  INSERT test::arith [
    { id: 1, num: 6 },
    { id: 2, num: 8 },
    { id: 3, num: 4 },
    { id: 4, num: 2 },
    { id: 5, num: 3 }
  ]
')
command 'from test::arith map { id + 42, id + id + id } '
---
> +-----------+----------------------------------+----------------------------------+-----------+----------------+
