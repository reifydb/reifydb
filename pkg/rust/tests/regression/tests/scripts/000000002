(admin 'create namespace test')
(admin 'create table test::item{field: int1}')
(command 'INSERT test::item [{field: -1 -2}]')
command 'from test::item map {field}'
---
> +----------+---------+
> |  rownum  |  field  |
> +----------+---------+
> |    1     |   -3    |
> +----------+---------+
>
