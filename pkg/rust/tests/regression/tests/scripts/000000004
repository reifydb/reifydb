(admin 'create namespace test')
(admin 'create table test::arith{id: int2, value: int2, num: int2}')
(command '
  INSERT test::arith [
    { id: 1, value: 1, num: 5  },
    { id: 1, value: 1, num: 10 },
    { id: 1, value: 2, num: 15 },
    { id: 2, value: 1, num: 10 },
    { id: 2, value: 1, num: 30 }
  ]
')
command '
    from test::arith
    map {a: 1}
'
---
> +-----------+----------------------------------+----------------------------------+-----+
> |  #rownum  |           #created_at            |           #updated_at            |  a  |
> +-----------+----------------------------------+----------------------------------+-----+
> |     5     |  1970-01-01T00:00:00.000000000Z  |  1970-01-01T00:00:00.000000000Z  |  1  |
> |     4     |  1970-01-01T00:00:00.000000000Z  |  1970-01-01T00:00:00.000000000Z  |  1  |
> |     3     |  1970-01-01T00:00:00.000000000Z  |  1970-01-01T00:00:00.000000000Z  |  1  |
> |     2     |  1970-01-01T00:00:00.000000000Z  |  1970-01-01T00:00:00.000000000Z  |  1  |
> |     1     |  1970-01-01T00:00:00.000000000Z  |  1970-01-01T00:00:00.000000000Z  |  1  |
> +-----------+----------------------------------+----------------------------------+-----+
