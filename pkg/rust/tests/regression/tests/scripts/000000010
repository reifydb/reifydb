(admin 'CREATE NAMESPACE test')
(admin 'CREATE TABLE test::t { id: int4, name: utf8 }')
(command 'INSERT test::t [{ id: 1, name: "a" }, { id: 2, name: "b" }]')
command 'LET $x = FROM test::t | FILTER id == 1; INSERT test::t $x'
---
> +-------------+---------+------------+
> |  namespace  |  table  |  inserted  |
> +-------------+---------+------------+
> |    test     |    t    |     1      |
> +-------------+---------+------------+
>
