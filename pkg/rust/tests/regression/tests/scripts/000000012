(admin 'CREATE NAMESPACE test')
(admin 'CREATE TABLE test::t { id: int4, name: utf8 }')
(command 'INSERT test::t [{ id: 1, name: "a" }, { id: 2, name: "b" }]')
command 'LET $x = 2; DELETE test::t FILTER id == $x RETURNING { id, name }'
---
> +-----------+----------------------------------+----------------------------------+------+--------+
> |  #rownum  |           #created_at            |           #updated_at            |  id  |  name  |
> +-----------+----------------------------------+----------------------------------+------+--------+
> |     2     |  1970-01-01T00:00:00.000000000Z  |  1970-01-01T00:00:00.000000000Z  |  2   |   b    |
> +-----------+----------------------------------+----------------------------------+------+--------+
>
