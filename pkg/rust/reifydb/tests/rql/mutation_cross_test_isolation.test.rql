# Cross-test mutation isolation — changed() in test B doesn't see mutations from test A

CREATE NAMESPACE tcmi;
CREATE TABLE tcmi::items { id: int4, name: text };

CREATE TEST tcmi::test_a {
    INSERT tcmi::items [{ id: 1, name: "A" }];
    testing::tables::changed("tcmi::items")
        | AGGREGATE { n: math::count(op) }
        | ASSERT { n == 1 }
};

CREATE TEST tcmi::test_b {
    INSERT tcmi::items [{ id: 2, name: "B" }];
    testing::tables::changed("tcmi::items")
        | AGGREGATE { n: math::count(op) }
        | ASSERT { n == 1 };
    testing::tables::changed("tcmi::items")
        | ASSERT { new_name == "B" }
};

RUN TESTS tcmi
