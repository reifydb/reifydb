# Cross-primitive mutation sequence ordering — mutation_seq increments globally

CREATE NAMESPACE cps;
CREATE TABLE cps::users { id: int4, name: text };
CREATE SERIES cps::metrics { ts: datetime, value: int4 } WITH { key: ts, precision: millisecond };

CREATE TEST cps::cross_primitive_sequence {
    INSERT cps::users [{ id: 1, name: "Alice" }];
    INSERT cps::metrics [{ value: 42 }];
    testing::tables::changed("cps::users")
        | ASSERT { sequence == 1 }
        | ASSERT { op == "insert" };
    testing::series::changed("cps::metrics")
        | ASSERT { sequence == 2 }
        | ASSERT { op == "insert" }
};

RUN TESTS cps
