# Basic DDL, DML, and query round-trip

CREATE NAMESPACE test;

CREATE TABLE test::users { id: int4, name: text };
INSERT test::users [{ id: 1, name: "Alice" }, { id: 2, name: "Bob" }];

CREATE TABLE test::items { id: int4, active: bool };
INSERT test::items [{ id: 1, active: true }, { id: 2, active: false }];

CREATE TEST test::query_after_insert {
    FROM test::users | ASSERT { id > 0 }
};

CREATE TEST test::filter_rows {
    FROM test::items | FILTER active == true | ASSERT { id == 1 }
};

RUN TESTS
