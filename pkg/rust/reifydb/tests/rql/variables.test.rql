# LET and variable usage

CREATE NAMESPACE test;

CREATE TEST test::let_and_assert {
    LET $x = 5;
    ASSERT { $x == 5 }
};

CREATE TEST test::let_with_arithmetic {
    LET $a = 10;
    LET $b = 20;
    ASSERT { $a + $b == 30 }
};

CREATE TEST test::let_with_string {
    LET $name = "Alice";
    ASSERT { $name == "Alice" }
};

RUN TESTS
