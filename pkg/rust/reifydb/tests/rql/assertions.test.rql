# ASSERT syntax coverage

CREATE NAMESPACE test;

CREATE TEST test::assert_true {
    ASSERT { true }
};

CREATE TEST test::assert_arithmetic {
    ASSERT { 1 + 1 == 2 }
};

CREATE TEST test::assert_comparison {
    ASSERT { 10 > 5 }
};

CREATE TEST test::assert_not_equal {
    ASSERT { 1 != 2 }
};

CREATE TEST test::assert_inline_pipeline {
    FROM [{ x: 1 }, { x: 2 }] | ASSERT { x > 0 }
};

RUN TESTS
