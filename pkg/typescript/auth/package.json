{
  "name": "@reifydb/auth",
  "version": "0.6.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm --sourcemap",
    "dev": "tsc --watch",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.config.ts",
    "test:integration:watch": "vitest --config vitest.config.ts",
    "test:integration:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:coverage": "pnpm test:integration:coverage",
    "pretest:integration": "pnpm build",
    "prepublishOnly": "pnpm build",
    "publish:npm": "pnpm publish --access public --no-git-checks"
  },
  "dependencies": {
    "@reifydb/core": "workspace:*",
    "@reifydb/client": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@solana/web3.js": "^1.95.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.12",
    "@vitest/coverage-v8": "^3.2.4",
    "bs58": "^6.0.0",
    "happy-dom": "^18.0.1",
    "react": "^19.1.1",
    "tsup": "^8.5.0",
    "tweetnacl": "^1.0.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "reifydb",
    "auth",
    "authentication",
    "wallet",
    "session"
  ],
  "files": [
    "dist/",
    "package.json",
    "readme.md",
    "license.md"
  ],
  "publishConfig": {
    "access": "public",
    "linkWorkspacePackages": false
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reifydb/reifydb.git",
    "directory": "pkg/typescript/auth"
  },
  "homepage": "https://reifydb.com",
  "bugs": {
    "url": "https://github.com/reifydb/reifydb/issues"
  }
}
