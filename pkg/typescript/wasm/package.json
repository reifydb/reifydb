{
  "name": "@reifydb/wasm",
  "version": "0.4.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "copy-wasm": "cp -r ../../webassembly/dist/bundler/ wasm/",
    "prebuild": "pnpm copy-wasm",
    "build": "tsup src/index.ts --dts --format esm --sourcemap",
    "test": "pnpm test:unit",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:watch": "vitest --config vitest.config.ts",
    "prepublishOnly": "pnpm build && pnpm test",
    "publish:npm": "pnpm publish --access public"
  },
  "dependencies": {
    "@reifydb/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "reifydb",
    "database",
    "wasm",
    "webassembly",
    "typescript"
  ],
  "files": [
    "dist/",
    "wasm/",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/reifydb/reifydb.git",
    "directory": "pkg/typescript/wasm"
  },
  "homepage": "https://github.com/reifydb/reifydb#readme",
  "bugs": {
    "url": "https://github.com/reifydb/reifydb/issues"
  }
}
