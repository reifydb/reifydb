{
  "name": "reifydb",
  "private": true,
  "version": "0.4.1",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "rm -rf node_modules core/node_modules core/dist client/node_modules client/dist react/node_modules react/dist coverage core/coverage client/coverage react/coverage .turbo core/.turbo client/.turbo react/.turbo pnpm-lock.yaml",
    "lint": "pnpm -r lint",
    "test": "pnpm build && pnpm -r --if-present --stream test",
    "test:unit": "pnpm build && pnpm -r --stream test:unit",
    "test:integration": "pnpm build && pnpm -r --stream test:integration",
    "test:coverage": "pnpm build && pnpm -r --stream test:coverage",
    "test:watch": "pnpm -r --stream test:unit:watch",
    "publish:all": "pnpm login && pnpm publish:core && pnpm publish:client && pnpm publish:console && pnpm publish:react && pnpm publish:shell && pnpm publish:wasm",
    "publish:core": "pnpm --filter @reifydb/core publish:npm",
    "publish:client": "pnpm --filter @reifydb/client publish:npm",
    "publish:console": "pnpm --filter @reifydb/console publish:npm",
    "publish:react": "pnpm --filter @reifydb/react publish:npm",
    "publish:shell": "pnpm --filter @reifydb/shell publish:npm",
    "publish:wasm": "pnpm --filter @reifydb/wasm publish:npm"
  },
  "dependencies": {
    "@reifydb/core": "link:core",
    "@reifydb/client": "link:core",
    "@reifydb/wasm": "link:wasm"
  }
}
